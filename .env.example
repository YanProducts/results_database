APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false

APP_URL=https://test.maniacquiz.tokyo

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# 本番はLog肥大化防止のため、DailyでLotateさせり
# Log_Channelはconfig/logging.phpのどの項目を使うか。dailyにすると「daily」の項目が使われ、結果的に日毎にローテートされる
LOG_CHANNEL=daily
#LOG_STACKは通常でsingleだから本番では記入しない
LOG_DEPRECATIONS_CHANNEL=null

#infoより上位の情報はLog::infoに記載
LOG_LEVEL=info

DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=2000
SESSION_ENCRYPT=false
SESSION_PATH=/

SESSION_DOMAIN=test.maniacquiz.tokyo
SESSION_COOKIE=results_database_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
